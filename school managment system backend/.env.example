# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<db_username>:<db_password>@cluster0.gtkokq3.mongodb.net/school_management?appName=Cluster0

# JWT secrets — use long random strings in production
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret

# Token lifetimes
JWT_ACCESS_EXPIRES=60m
JWT_REFRESH_EXPIRES=7d

# Server
PORT=5000
NODE_ENV=development

# CORS — comma-separated allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
